---
import yaml from 'js-yaml';
// links.yaml を生のテキストとして取り込み、ビルド時にパースする
import yamlRaw from '../data/links.yaml?raw';

const data = yaml.load(yamlRaw);

const site = data.site ?? {};
const links = data.links ?? [];
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>砂時計links</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;700&display=swap" rel="stylesheet">
    <!-- FOUC防止: レンダリング前にテーマを適用 -->
    <script is:inline>
      (function() {
        const VALID = ['light', 'dark'];
        const saved = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        const theme = VALID.includes(saved) ? saved : preferred;
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* ─── ダークモード (デフォルト) ─── */
      :root {
        --accent:     #ff772d;
        --accent-dim: #99461b;
        --accent-mid: #ff9355;
        --bg:         #0a0a0a;
        --bg-card:    #111;
        --bg-bar:     #1f150f;
        --border:     #3d2a1e;
        --glow:       rgba(255,119,45,0.04);
        --scanline:   rgba(0,0,0,0.15);
        --hover-bg:   rgba(255,119,45,0.05);
        --active-bg:  rgba(255,119,45,0.12);
        --mono:       'Fira Code', monospace;
      }

      /* ─── ライトモード (モノクロ) ─── */
      [data-theme="light"] {
        --accent:     #1a1a1a;
        --accent-dim: #666666;
        --accent-mid: #333333;
        --bg:         #f5f5f5;
        --bg-card:    #e8e8e8;
        --bg-bar:     #d0d0d0;
        --border:     #b0b0b0;
        --glow:       rgba(0,0,0,0.02);
        --scanline:   rgba(0,0,0,0.03);
        --hover-bg:   rgba(0,0,0,0.05);
        --active-bg:  rgba(0,0,0,0.12);
      }

      html, body {
        background: var(--bg);
        color: var(--accent);
        font-family: var(--mono);
        font-size: 14px;
        line-height: 1.6;
        min-height: 100vh;
        /* CRT scanline overlay */
        background-image: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          var(--scanline) 2px,
          var(--scanline) 4px
        );
        transition: background-color 0.2s, color 0.2s;
      }

      /* フォスファーグロー */
      body::before {
        content: '';
        position: fixed; inset: 0;
        background: radial-gradient(ellipse at center, var(--glow) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }

      .terminal {
        position: relative;
        z-index: 1;
        max-width: 640px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      /* ─── ウィンドウ枠 ─── */
      .window {
        border: 1px solid var(--border);
        overflow: hidden;
        transition: border-color 0.2s;
      }

      .window-bar {
        background: var(--bg-bar);
        border-bottom: 1px solid var(--border);
        padding: 0.4rem 0.75rem;
        font-size: 11px;
        color: var(--accent-dim);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        letter-spacing: 0.05em;
        transition: background-color 0.2s;
      }

      .window-body {
        padding: 1.5rem;
      }

      /* ─── コマンドライン ─── */
      .cmd-line {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 0.25rem;
        font-size: 13px;
        align-items: center;
      }
      .prompt { color: var(--accent-dim); user-select: none; }
      .cmd-text { color: var(--accent); }

      .output-line {
        color: var(--accent-dim);
        font-size: 12px;
        margin-bottom: 1.25rem;
        padding-left: 1rem;
        white-space: pre-line;
      }

      /* ─── リンクセクション ─── */
      .section-label {
        font-size: 11px;
        color: var(--accent-dim);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.4rem;
        margin-bottom: 1rem;
      }

      .link-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
      }

      .link-item a {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 0.75rem;
        border: 1px solid transparent;
        border-radius: 2px;
        text-decoration: none;
        color: var(--accent);
        font-size: 13px;
        transition: background-color 0.15s, border-color 0.15s;
      }

      .link-item a:hover {
        border-color: var(--accent-dim);
        background: var(--hover-bg);
      }

      .link-item a:hover .link-cmd { color: var(--accent); }
      .link-item a:active { background: var(--active-bg); }

      .link-dollar { color: var(--accent-dim); user-select: none; }
      .link-cmd    { color: var(--accent-mid); }
      .link-arrow  { color: var(--accent-dim); margin-left: auto; font-size: 11px; }
      .link-name   { color: var(--accent); }

      /* ─── テーマ切替ボタン ─── */
      .theme-toggle-btn {
        background: none;
        border: none;
        font-family: var(--mono);
        font-size: 13px;
        color: var(--accent);
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .theme-toggle-btn:hover .theme-toggle-cmd { color: var(--accent-mid); }
      .theme-badge {
        color: var(--accent-dim);
        font-size: 12px;
        border: 1px solid var(--border);
        padding: 0 0.35rem;
        border-radius: 2px;
        transition: color 0.15s, border-color 0.15s;
      }
      .theme-toggle-btn:hover .theme-badge {
        color: var(--accent);
        border-color: var(--accent-dim);
      }

      /* ─── フッター ─── */
      .footer-line {
        font-size: 11px;
        color: var(--accent-dim);
        border-top: 1px solid var(--border);
        padding-top: 0.75rem;
        display: flex;
        justify-content: space-between;
      }

      /* ─── カーソル点滅 ─── */
      .cursor {
        display: inline-block;
        width: 8px;
        height: 14px;
        background: var(--accent);
        vertical-align: text-bottom;
        animation: blink 1s step-end infinite;
      }
      @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

      /* ─── タイプライターアニメ ─── */
      .typewriter {
        overflow: hidden;
        white-space: nowrap;
        border-right: none;
        width: 0;
        animation: typing 0.3s steps(8, end) 0.3s forwards;
      }
      @keyframes typing { from{width:0} to{width:20%} }

      /* ─── 実行フィードバック (JS制御) ─── */
      .exec-toast {
        position: fixed;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%) translateY(10px);
        background: var(--bg-card);
        border: 1px solid var(--accent-dim);
        color: var(--accent);
        font-family: var(--mono);
        font-size: 12px;
        padding: 0.5rem 1rem;
        border-radius: 2px;
        opacity: 0;
        transition: opacity 0.2s, transform 0.2s;
        pointer-events: none;
        z-index: 100;
        white-space: nowrap;
      }
      .exec-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      @media (max-width: 480px) {
        .terminal { padding: 1rem 0.75rem 3rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        .typewriter { animation: none; width: 100%; }
        .cursor { animation: none; }
      }
    </style>
  </head>
<body>

<div class="terminal">
  <div class="window">

    <div class="window-bar">
      {site.user} &nbsp;—&nbsp; ~/links &nbsp;—&nbsp; bash
    </div>

    <div class="window-body">
      <!-- whoami -->
      <div class="cmd-line">
        <span class="prompt">~/links $</span>

        <span class="cmd-text typewriter">whoami</span>
      </div>
      <div class="output-line">
        {site.whoami}
      </div>

      <!-- ls -->
      <div class="cmd-line">
        <span class="prompt">~/links $</span>
        <span class="cmd-text">ls -la ./links</span>
      </div>

      <div style="height:0.75rem"></div>

      <p class="section-label">// links [{links.length}]</p>

      <ul class="link-list">
        {links.map((link) => (
          <li class="link-item">
            <a
              href={link.url}
              data-cmd={link.cmd.replace(/^\.\//, '')}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="link-dollar">$</span>
              <span class="link-cmd">{link.cmd}</span>
              <span class="link-arrow">──▶</span>
              <span class="link-name">{link.name}</span>
            </a>
          </li>
        ))}
      </ul>

      <!-- テーマ切替 & カーソル行 -->
      <div class="cmd-line">
        <span class="prompt">~/links $</span>
        <button class="theme-toggle-btn" id="theme-toggle" aria-label="テーマ切替">
          <span class="theme-toggle-cmd">theme --toggle</span>
          <span class="theme-badge" id="theme-badge">[dark]</span>
        </button>
      </div>
      <div class="cmd-line">
        <span class="prompt">~/links $</span>
        <span class="cursor"></span>
      </div>

      <!-- フッター -->
      <div style="height:1.5rem"></div>
      <div class="footer-line">
        <span>// [EOF]</span>
        <span>{links.length} links · {site.year}</span>
      </div>

    </div>
  </div>
</div>

<!-- 実行トースト -->
<div class="exec-toast" id="toast"></div>

<script>
  // ─── テーマ切替 ───
  const themeToggle = document.getElementById('theme-toggle');
  const themeBadge  = document.getElementById('theme-badge');

  const VALID_THEMES = ['light', 'dark'] as const;
  type Theme = typeof VALID_THEMES[number];

  function normalizeTheme(value: string | null | undefined): Theme {
    return VALID_THEMES.includes(value as Theme) ? (value as Theme) : 'dark';
  }

  function setTheme(theme: Theme) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    if (themeBadge) themeBadge.textContent = `[${theme}]`;
  }

  // 初期バッジ表示 (head側スクリプトで設定済みの値を正規化して使用)
  const initialTheme = normalizeTheme(document.documentElement.getAttribute('data-theme'));
  if (themeBadge) themeBadge.textContent = `[${initialTheme}]`;

  themeToggle?.addEventListener('click', () => {
    const current = normalizeTheme(document.documentElement.getAttribute('data-theme'));
    setTheme(current === 'dark' ? 'light' : 'dark');
  });

  // ─── リンククリック時トースト ───
  const toast = document.getElementById('toast');

  document.querySelectorAll('.link-item a').forEach((a) => {
    a.addEventListener('click', (e) => {
      const link = a as HTMLAnchorElement;
      const cmd = link.dataset.cmd ?? 'run';
      e.preventDefault();
      if (toast) {
        toast.textContent = `$ executing ${cmd}... ✓`;
        toast.classList.add('show');
      }
      setTimeout(() => {
        toast?.classList.remove('show');
        window.open(link.href, '_blank', 'noopener');
      }, 700);
    });
  });
</script>

</body>
</html>
